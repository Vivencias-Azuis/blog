{
  "name": "vivencias-azuis-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "dev:external": "NEXT_DIST_DIR=.next-dev next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "db:generate": "npx drizzle-kit generate",
    "db:push": "npx drizzle-kit push",
    "llms": "node scripts/generate-llms.js",
    "cta:audit": "node scripts/audit-post-cta.js",
    "content:generate": "node scripts/generate-content.js",
    "calendar:check": "node scripts/check-publication-calendar.js",
    "normalize-filenames": "node scripts/normalize-filenames.js --dry-run",
    "normalize-filenames:execute": "node scripts/normalize-filenames.js --execute",
    "convert-md-to-mdx": "node scripts/convert-md-to-mdx.js --dry-run",
    "convert-md-to-mdx:execute": "node scripts/convert-md-to-mdx.js --execute",
    "download-external-images": "node scripts/download-external-images.js",
    "fix-image-names": "node scripts/fix-image-names.js",
    "build:full": "npm run llms && npm run build"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.5",
    "@libsql/client": "^0.17.3",
    "@mdx-js/loader": "^3.0.0",
    "@mdx-js/react": "^3.0.0",
    "@next/mdx": "^15.5.15",
    "@serwist/next": "^9.5.7",
    "@types/mdx": "^2.0.10",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.15",
    "next-mdx-remote": "^6.0.0",
    "openai": "^5.12.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reading-time": "^1.5.0",
    "remark-gfm": "^4.0.0",
    "stripe": "^18.5.0",
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.15",
    "jsdom": "^29.0.2",
    "postcss": "^8",
    "serwist": "^9.5.7",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "glob": "^13.0.6",
    "mdast-util-to-hast": "^13.2.1",
    "picomatch": "^4.0.4",
    "source-map": "^0.7.6"
  }
}
